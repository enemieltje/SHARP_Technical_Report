@article{Chen:PurgeSystems,
  author   = {Chen,Dongfang and Chen,Zhiqiang and Chang,Kuanyu and Guo,Ruifeng and Hu,Song and Pei,Pucheng and Xu,Xiaoming},
  year     = {2025},
  title    = {A review on hydrogen supply subsystem of proton exchange membrane fuel cell system: Configuration, core components, theoretical model, and control strategy},
  journal  = {International journal of hydrogen energy},
  volume   = {133},
  pages    = {38-62},
  abstract = {This review provides a comprehensive survey of the design and optimization of hydrogen supply subsystems in proton exchange membrane fuel cell (PEMFC) systems, with particular emphasis on the importance of cycling modes in enhancing hydrogen utilization and cell efficiency. The review starts with the introduction of hydrogen storage methods, exploring multiple modes of hydrogen supply, including flow-through, dead-end, and recirculation modes, each of which has its own unique advantages and challenges. The recirculation mode improves system efficiency by recycling unreacted hydrogen, but also places greater demands on the design of the recirculation pumps, which need to be long-life and vane cavitation-resistant, and the ejectors, which need to be able to operate efficiently across a wide power range. In addition, pressure dynamic control and purge strategy play a key role in maintaining fuel cell stability and life extension. Future research will focus on developing more intelligent control algorithms to adapt the fuel cell to different operating conditions, and exploring new materials and technologies to improve the durability of system and environmental resilience. These advances will contribute to the application of hydrogen supply subsystems in PEMFC technology, promoting its development towards higher efficiency, longer life and wider application.  •Comprehensive review of hydrogen supply subsystems for PEM fuel cell systems.•Detailed comparison of flow-through, dead-end, and recirculation hydrogen supply modes.•Analysis of hydrogen recirculation pumps and ejectors for system efficiency improvement.•Summary and analysis of advanced control strategies for fuel cell stability and durability.•Future directions identified for intelligent control algorithms and novel materials.},
  keywords = {Control strategy; Core components of recirculation mode; Hydrogen supply subsystem; Proton exchange membrane fuel cell systems; Theoretical model},
  isbn     = {0360-3199},
  language = {English}
}

